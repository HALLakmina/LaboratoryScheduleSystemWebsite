APP_ENV=local
ALLOWED_ORIGINS=http://localhost

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your-database-password
DB_NAME=timetable_system
JWT_KEY=your-secret-key
DOMAIN=localhost

SEED_ADMIN_PASSWORD=
SEED_LECTURER_PASSWORD=

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_ENCRYPTION=tls
SMTP_AUTH=true
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Laboratory Schedule System

WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_API_VERSION=v21.0
WHATSAPP_DEFAULT_COUNTRY_CODE=94
WHATSAPP_TEMPLATE_LANGUAGE=en_US
WHATSAPP_TEMPLATE_ADMIN_NEW_REQUEST=admin_new_lecture_request
WHATSAPP_TEMPLATE_LECTURER_CONFIRMED=lecture_request_confirmed
WHATSAPP_TEMPLATE_LECTURER_CANCELED=lecture_request_canceled
